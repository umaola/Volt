{
  "name": "frontend",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "mobile:build": "next build && npx cap sync",
    "mobile:android": "next build && npx cap sync && npx cap open android",
    "mobile:ios": "next build && npx cap sync && npx cap open ios",
    "build:android": "next build && npx cap sync && cd android && ./gradlew assembleDebug",
    "build:ios": "next build && npx cap sync && npx cap build ios --configuration=Debug"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "firebase": "^12.14.0",
    "input-otp": "^1.4.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.0",
    "shadcn": "^4.9.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^54.14.0"
  }
}

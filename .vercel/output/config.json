{
  "version": 3,
  "routes": [
    {
      "src": "/_next/__private/trace",
      "dest": "/404",
      "status": 404,
      "continue": true
    },
    {
      "src": "/404/?",
      "status": 404,
      "continue": true
    },
    {
      "src": "^(?:/((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/]+\\.\\w+))/$",
      "headers": {
        "Location": "/$1"
      },
      "status": 308,
      "missing": [
        {
          "type": "header",
          "key": "x-nextjs-data"
        }
      ]
    },
    {
      "src": "^(?:/((?!\\.well-known(?:/.*)?)(?:[^/]+/)*[^/\\.]+))$",
      "headers": {
        "Location": "/$1/"
      },
      "status": 308
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/_next/data/(.*)",
      "dest": "/_next/data/$1",
      "check": true
    },
    {
      "src": "/_next/data/(.*)",
      "status": 404
    },
    {
      "handle": "resource"
    },
    {
      "src": "/.*",
      "status": 404
    },
    {
      "handle": "miss"
    },
    {
      "src": "/_next/static/.+",
      "status": 404,
      "check": true,
      "dest": "/_next/static/not-found.txt",
      "headers": {
        "content-type": "text/plain; charset=utf-8"
      }
    },
    {
      "handle": "hit"
    },
    {
      "src": "/_next/static/(?:[^/]+/pages|pages|chunks|runtime|css|image|media|fWXdc\\-8dvhBqn6VyS7RHC)/.+",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true,
      "important": true
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": ".*",
      "dest": "/404"
    }
  ],
  "overrides": {
    "404.html": {
      "path": "404",
      "contentType": "text/html; charset=utf-8"
    },
    "_not-found/index.html": {
      "path": "_not-found/index",
      "contentType": "text/html; charset=utf-8"
    },
    "404/index.html": {
      "path": "404/index",
      "contentType": "text/html; charset=utf-8"
    },
    "calculator/index.html": {
      "path": "calculator/index",
      "contentType": "text/html; charset=utf-8"
    },
    "dashboard/index.html": {
      "path": "dashboard/index",
      "contentType": "text/html; charset=utf-8"
    },
    "index.html": {
      "path": "index",
      "contentType": "text/html; charset=utf-8"
    },
    "insights/index.html": {
      "path": "insights/index",
      "contentType": "text/html; charset=utf-8"
    },
    "login/index.html": {
      "path": "login/index",
      "contentType": "text/html; charset=utf-8"
    },
    "onboarding/index.html": {
      "path": "onboarding/index",
      "contentType": "text/html; charset=utf-8"
    },
    "profile/index.html": {
      "path": "profile/index",
      "contentType": "text/html; charset=utf-8"
    },
    "subscription/index.html": {
      "path": "subscription/index",
      "contentType": "text/html; charset=utf-8"
    }
  },
  "framework": {
    "slug": "nextjs",
    "version": "16.2.6"
  },
  "crons": []
}
